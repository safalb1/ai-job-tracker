# Copy this file to `.env` and fill in your keys for LOCAL runs of
# scripts/fetch_jobs.py. The real `.env` is gitignored and never committed.
# In GitHub Actions these same names come from encrypted repo secrets instead.

# Jooble — broad IN/US/UK coverage. Free key: https://jooble.org/api/about
JOOBLE_KEY=

# Adzuna — international jobs + real salaries. Free keys: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
